<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<location path="." inheritInChildApplications="false">
		<system.webServer>
			<modules>
				<remove name="WebDAVModule" />
			</modules>
			<handlers>
				<remove name="aspNetCore" />
				<remove name="WebDAV" />
				<!-- I removed the following handlers too, but these
                 can probably be ignored for most installations -->
				<remove name="ExtensionlessUrlHandler-Integrated-4.0" />
				<remove name="OPTIONSVerbHandler" />
				<remove name="TRACEVerbHandler" />
				<add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
			</handlers>
			<rewrite>
				<rules>
					<rule name="HTTPS Redirect" stopProcessing="true">
						<match url="(.*)" />
						<conditions>
							<add input="{HTTPS}" pattern="^OFF$" />
						</conditions>
						<action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}" appendQueryString="false" />
					</rule>
				</rules>
			</rewrite>
			<aspNetCore processPath="%LAUNCHER_PATH%" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="InProcess">
				<environmentVariables>
					<environmentVariable name="ASPNETCORE_ENVIRONMENT" value="" />
					<environmentVariable name="DB_CONNECTION_STRING" value="" />
					<environmentVariable name="SENDGRID_API_KEY" value="" />
					<environmentVariable name="SENDPULSE_API_KEY" value="" />
					<environmentVariable name="BREVO_API_KEY" value="" />
					<environmentVariable name="AWIN_TOKEN_1" value="" />
					<environmentVariable name="PAGARME_ENCRYPTION_KEY" value="" />
					<environmentVariable name="PAGARME_API_KEY" value="" />
					<environmentVariable name="ASPNETCORE_HTTPS_PORT" value="" />
					<environmentVariable name="COMPLUS_ForceENC" value="" />
					<environmentVariable name="ASPNETCORE_HOSTINGSTARTUPASSEMBLIES" value="" />
					<environmentVariable name="DOTNET_STARTUP_HOOKS" value="" />
					<environmentVariable name="ASPNETCORE_AUTO_RELOAD_WS_ENDPOINT" value="" />
					<environmentVariable name="DOTNET_MODIFIABLE_ASSEMBLIES" value="" />
					<environmentVariable name="ASPNETCORE_AUTO_RELOAD_WS_KEY" value="" />
					<environmentVariable name="ASPNETCORE_AUTO_RELOAD_VDIR" value="" />
					<environmentVariable name="ASAAS_API_KEY" value="" />
					<environmentVariable name="ASAAS_PAYMENT_CONFIRMED_TOKEN" value="" />
					<environmentVariable name="ASAAS_BASE_URL" value="" />
				</environmentVariables>
			</aspNetCore>
		</system.webServer>
	</location>
</configuration>
